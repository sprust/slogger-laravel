{
    "name": "slogger/laravel",
    "description": "Tracing and observability for Laravel with dispatchers, masking, and profiling.",
    "license": "MIT",
    "authors": [
        {
            "name": "Pavel",
            "email": "sppetrovich@mail.ru"
        }
    ],
    "keywords": [
        "laravel",
        "tracing",
        "observability",
        "logging",
        "monitoring",
        "profiling",
        "debugging"
    ],
    "require": {
        "ext-pcntl": "*",
        "ext-posix": "*",
        "laravel/framework": "^10.0 | ^11.0 | ^12.0",
        "symfony/process": "^6.4|^7.0",
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "SLoggerLaravel\\": "src/"
        }
    },
    "autoload-dev": {
      "psr-4": {
        "SLoggerLaravel\\Tests\\": "tests/",
        "App\\": "workbench/app/"
      }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SLoggerLaravel\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^8.0 | ^9.0 | ^10.0",
        "guzzlehttp/guzzle": "^7.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5 | ^11.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    }
}
